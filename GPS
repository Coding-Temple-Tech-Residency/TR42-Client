const pipelinePath = [
  { lat: 24.7, lng: 46.6 },
  { lat: 24.8, lng: 46.8 },
  { lat: 25.0, lng: 47.0 }
];

const pipeline = new google.maps.Polyline({
  path: pipelinePath,
  geodesic: true,
  strokeColor: "#FF0000",
  strokeOpacity: 1.0,
  strokeWeight: 3
});

pipeline.setMap(map);


const marker = new google.maps.Marker({
  position: center,
  map: map
});

const infoWindow = new google.maps.InfoWindow({
  content: "<h3>Oil Well A</h3><p>Production: 5000 bpd</p>"
});




marker.addListener("click", () => {
  infoWindow.open(map, marker);
});

function updateVehicle(marker) {
  setInterval(() => {
    const newLat = marker.getPosition().lat() + (Math.random() - 0.5) * 0.01;
    const newLng = marker.getPosition().lng() + (Math.random() - 0.5) * 0.01;

    marker.setPosition({ lat: newLat, lng: newLng });
  }, 3000);
}
