<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Messaging</title>

<style>
body {
  margin: 0;
  font-family: "Inter", "Segoe UI", Arial;
  display: flex;
  height: 100vh;
  background: #f6f7fb;
}

/* SIDEBAR */
.sidebar {
  width: 260px;
  background: #111827;
  color: white;
  padding: 15px;
}

.vendor {
  padding: 12px;
  border-radius: 10px;
  margin-bottom: 6px;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.vendor:hover {
  background: #1f2937;
}

.active {
  background: #2563eb;
}

.status {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}

.online { background: #22c55e; }
.offline { background: #9ca3af; }

/* CHAT AREA */
.chat {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* HEADER */
.header {
  background: white;
  padding: 12px 16px;
  border-bottom: 1px solid #e5e7eb;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-weight: 600;
}

.header small {
  color: gray;
  font-weight: normal;
}

/* SEARCH */
input {
  padding: 8px 10px;
  border-radius: 8px;
  border: 1px solid #ddd;
  outline: none;
}

/* MESSAGES */
.messages {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* BUBBLES */
.bubble {
  max-width: 60%;
  padding: 10px 14px;
  border-radius: 16px;
  font-size: 14px;
  line-height: 1.4;
}

.me {
  background: #2563eb;
  color: white;
  align-self: flex-end;
  border-bottom-right-radius: 4px;
}

.them {
  background: white;
  border: 1px solid #e5e7eb;
  align-self: flex-start;
  border-bottom-left-radius: 4px;
}

/* INPUT */
.input-area {
  display: flex;
  padding: 12px;
  background: white;
  border-top: 1px solid #e5e7eb;
}

.input-area input {
  flex: 1;
}

button {
  margin-left: 8px;
  border: none;
  border-radius: 8px;
  padding: 10px 14px;
  background: #2563eb;
  color: white;
  cursor: pointer;
}

button:hover {
  opacity: 0.9;
}

.star {
  background: #facc15;
  color: black;
}

/* HIGHLIGHT */
.highlight {
  background: yellow;
}
</style>
</head>

<body>

<!-- SIDEBAR -->
<div class="sidebar" id="vendors">
  <h3>Vendors</h3>
</div>

<!-- CHAT -->
<div class="chat">

  <div class="header">
    <div id="title">Select Vendor</div>
    <input id="search" placeholder="Search messages..." oninput="search()" />
  </div>

  <div class="messages" id="messages"></div>

  <div class="input-area">
    <input id="input" placeholder="Type message..." />
    <button onclick="send()">Send</button>
    <button class="star" onclick="favorite()">★</button>
  </div>

</div>

<script>

let username = "You";
let selectedVendor = null;
let searchText = "";

let status = {
  VendorA: true,
  VendorB: false,
  VendorC: true
};

let conversations = {
  VendorA: [],
  VendorB: [],
  VendorC: []
};

let unread = {
  VendorA: 0,
  VendorB: 0,
  VendorC: 0
};

/* RENDER VENDORS */
function renderVendors() {
  let box = document.getElementById("vendors");
  box.innerHTML = "<h3>Vendors</h3>";

  Object.keys(conversations).forEach(v => {
    let dot = status[v] ? "online" : "offline";
    let badge = unread[v] > 0 ? `(${unread[v]})` : "";

    box.innerHTML += `
      <div class="vendor ${selectedVendor === v ? "active" : ""}" onclick="selectVendor('${v}')">
        <span style="display:flex; gap:8px; align-items:center;">
          <span class="status ${dot}"></span>
          ${v}
        </span>
        <span>${badge}</span>
      </div>
    `;
  });
}

/* SELECT */
function selectVendor(v) {
  selectedVendor = v;
  unread[v] = 0;

  document.getElementById("title").innerHTML =
    `Chat with ${v} <small>${status[v] ? "Online" : "Offline"}</small>`;

  conversations[v].forEach(m => m.read = true);

  render();
  renderVendors();
}

/* RENDER CHAT */
function render() {
  let box = document.getElementById("messages");
  box.innerHTML = "";

  if (!selectedVendor) return;

  conversations[selectedVendor].forEach(m => {

    if (searchText && !m.text.toLowerCase().includes(searchText)) return;

    let text = m.text;

    if (searchText) {
      let reg = new RegExp(`(${searchText})`, "gi");
      text = text.replace(reg, `<span class="highlight">$1</span>`);
    }

    let cls = m.sender === username ? "bubble me" : "bubble them";

    box.innerHTML += `<div class="${cls}">${text}</div>`;
  });

  box.scrollTop = box.scrollHeight;
}

/* SEND */
function send() {
  if (!selectedVendor) return;

  let input = document.getElementById("input");
  let text = input.value;
  if (!text) return;

  conversations[selectedVendor].push({
    sender: username,
    text,
    read: true,
    favorite: false
  });

  input.value = "";
  render();
}

/* FAVORITE */
function favorite() {
  let c = conversations[selectedVendor];
  if (c.length > 0) {
    c[c.length - 1].favorite = true;
  }
}

/* SEARCH */
function search() {
  searchText = document.getElementById("search").value.toLowerCase();
  render();
}

/* SIMULATE MESSAGES */
setInterval(() => {
  let v = "VendorA";

  conversations[v].push({
    sender: v,
    text: "New incoming message",
    read: false
  });

  if (v !== selectedVendor) unread[v]++;

  render();
  renderVendors();
}, 6000);

/* INIT */
renderVendors();

</script>

</body>
</html>
